ANTHROPIC_API_KEY=               # (legacy - no longer used)

# ── LLM Provider ──────────────────────────────────────────────────────────────
# "gemini" (default) or "openai" (covers OpenAI + any OpenAI-compatible API)
LLM_PROVIDER=gemini

# ── Gemini (LLM_PROVIDER=gemini) ─────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ── OpenAI / OpenAI-compatible (LLM_PROVIDER=openai) ─────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Leave empty for official OpenAI. Set to custom base URL for compatible APIs:
#   Ollama (local):   http://localhost:11434/v1
#   Together AI:      https://api.together.xyz/v1
#   Groq:             https://api.groq.com/openai/v1
#   Mistral:          https://api.mistral.ai/v1
#   LM Studio:        http://localhost:1234/v1
OPENAI_BASE_URL=

# ── Loop + Sandbox ────────────────────────────────────────────────────────────
MAX_LOOP_ITERATIONS=6
EXECUTION_TIMEOUT_SECONDS=30
MAX_UPLOAD_MB=200
SANDBOX_MEMORY_LIMIT_GB=8
# BLAS/OpenMP threads inside sandboxed code (keep 1 on many-core machines)
SANDBOX_BLAS_THREADS=1

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_SECRET_KEY=change-me-in-production
